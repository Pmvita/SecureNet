
# SecureNet Environment Configuration

# Slack Bot Token for sending alerts
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# Slack channel name (e.g., #alerts)
SLACK_CHANNEL=#your-channel-name

# AWS Access (if needed for log ingestion or integration)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1

# Email alert config (for future use)
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
EMAIL_USERNAME=your-email@example.com
EMAIL_PASSWORD=your-password
EMAIL_FROM=alerts@example.com
EMAIL_TO=security-team@example.com